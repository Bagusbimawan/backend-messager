# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL Docker Local)
# NOTE: Gunakan "localhost" bila menjalankan backend (bun run dev) secara terpisah dari MacOS.
# NOTE: Gunakan "postgres" jika menjalankan `backend` murni dari dalam docker-compose.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kwento_db
DB_USER=kwento_user
DB_PASSWORD=kwento_dev_pass

# Redis (Redis Docker Local)
# Gunakan "localhost" bila menjalankan backend terpisah, atau "redis" jika dalam container.
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=kwento_dev_jwt_secret_minimum_32_chars_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=kwento_dev_refresh_secret_min_32chars
REFRESH_TOKEN_EXPIRES_IN=30d

# AWS S3 (Mock/Local Development)
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=kwento-media-bucket
AWS_ACCESS_KEY_ID=dev_key_id
AWS_SECRET_ACCESS_KEY=dev_secret_key

# CORS
ALLOWED_ORIGINS=
