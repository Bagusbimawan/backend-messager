# Server
PORT=3000
NODE_ENV=production

# Database (AWS RDS PostgreSQL)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=kwento_db
DB_USER=kwento_user
DB_PASSWORD=your_secure_password

# Redis (AWS ElastiCache)
REDIS_URL=redis://your-elasticache-endpoint:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=30d

# AWS S3 (Profile photo storage)
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=kwento-media-bucket
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# AWS SNS (Push Notifications)
AWS_SNS_PLATFORM_APP_ARN_IOS=arn:aws:sns:ap-southeast-1:ACCOUNT_ID:app/APNS/kwento-ios
AWS_SNS_PLATFORM_APP_ARN_ANDROID=arn:aws:sns:ap-southeast-1:ACCOUNT_ID:app/GCM/kwento-android

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3001
